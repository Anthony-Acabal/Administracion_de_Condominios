	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="CondominioDB"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<parameter name="P_ID_PROPIETARIO" class="java.lang.Integer">
		<parameterDescription><![CDATA[Solicitar id del propietario]]></parameterDescription>
	</parameter>
	<parameter name="P_ID_PAGO_CUOTA" class="java.lang.Integer">
		<parameterDescription><![CDATA[Solicitar id de pago de cuota]]></parameterDescription>
	</parameter>
	<queryString>
		<![CDATA[SELECT 
    a.id_pago_cuota, 
    CONCAT(b.primer_nombre, ' ', b.primer_apellido) nombre, 
    b.id_casa,
    b.telefono,
    CONCAT('Q', c.cuota, '.00') cuota,
    FORMAT(a.pago, 'MMMM ''del'' yyyy', 'es-ES') pago,
    FORMAT(a.fecha_pago, 'MMMM ''del'' yyyy', 'es-ES') fecha_pago
FROM pago_cuota a
INNER JOIN propietario b 
    ON a.id_propietario = b.id_propietario
INNER JOIN cuota c 
    ON a.id_cuota = c.id_cuota
WHERE a.id_propietario = $P{P_ID_PROPIETARIO} 
AND a.id_pago_cuota = $P{P_ID_PAGO_CUOTA} ]]>
	</queryString>
