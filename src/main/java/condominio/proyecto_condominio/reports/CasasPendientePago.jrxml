<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="CasasPendientePago" pageWidth="612" pageHeight="792" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="e15388e1-5541-498c-bc47-f1bfbc3a5bcc">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="CondominioDB"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<parameter name="P_MES" class="java.lang.Integer">
		<parameterDescription><![CDATA[Solicitar mes]]></parameterDescription>
	</parameter>
	<parameter name="P_ANIO" class="java.lang.Integer">
		<parameterDescription><![CDATA[Solicitar año]]></parameterDescription>
	</parameter>
	<queryString>
		<![CDATA[    WITH Meses AS
(
    SELECT 1 mes
    UNION ALL SELECT 2
    UNION ALL SELECT 3
    UNION ALL SELECT 4
    UNION ALL SELECT 5
    UNION ALL SELECT 6
    UNION ALL SELECT 7
    UNION ALL SELECT 8
    UNION ALL SELECT 9
    UNION ALL SELECT 10
    UNION ALL SELECT 11
    UNION ALL SELECT 12
)

SELECT
    p.id_casa,

    p.primer_nombre
    + ' '
    + ISNULL(p.segundo_nombre + ' ', '')
    + p.primer_apellido AS nombre_propietario,

    p.telefono,
	(SELECT TOP 1 CONCAT('Q',cuota) FROM cuota WHERE id_estado = 2 ORDER BY 1 DESC) cuota,
    FORMAT(
        DATEFROMPARTS($P{P_ANIO}, m.mes, 1),
        'MMMM - yyyy',
        'es-ES'
    ) AS fecha_pendiente

FROM propietario p

CROSS JOIN Meses m

WHERE
(
    $P{P_MES} IS NULL
    OR m.mes = $P{P_MES}
)
AND
(
    2026 < YEAR(GETDATE())
    OR m.mes <= MONTH(GETDATE())
)
AND NOT EXISTS
(
    SELECT 1
    FROM pago_cuota pc
    WHERE pc.id_propietario = p.id_propietario
    AND MONTH(pc.pago) = m.mes
    AND YEAR(pc.pago) = $P{P_ANIO}
)

ORDER BY m.mes ASC, p.id_casa ASC]]>
	</queryString>
	<field name="id_casa" class="java.lang.Integer">
		<property name="com.jaspersoft.studio.field.name" value="id_casa"/>
		<property name="com.jaspersoft.studio.field.label" value="id_casa"/>
	</field>
	<field name="nombre_propietario" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.name" value="nombre_propietario"/>
		<property name="com.jaspersoft.studio.field.label" value="nombre_propietario"/>
