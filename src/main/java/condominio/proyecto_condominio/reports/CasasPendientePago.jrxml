		<property name="com.jaspersoft.studio.field.label" value="cuota"/>
	</field>
	<field name="fecha_pendiente" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.name" value="fecha_pendiente"/>
		<property name="com.jaspersoft.studio.field.label" value="fecha_pendiente"/>
	</field>
