<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15.0" prefHeight="400.0" prefWidth="500.0" style="-fx-background-color: #f3f4f6;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="proyecto_condominio.ui.OlvidoContrasenaController">
   <padding>
      <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
   </padding>
   <children>
      <Label text="Recuperación de Contraseña" textFill="#1e3a8a">
         <font>
            <Font name="System Bold" size="22.0" />
         </font>
         <VBox.margin>
            <Insets bottom="10.0" />
         </VBox.margin>
      </Label>
      <VBox spacing="5.0" maxWidth="300.0">
         <children>
            <Label text="Nombre de Usuario:" textFill="#374151">
               <font>
                  <Font name="System Bold" size="13.0" />
               </font>
            </Label>
            <TextField fx:id="txtUsuario" promptText="Ingrese su usuario" prefHeight="35.0" />
         </children>
      </VBox>
      <VBox spacing="5.0" maxWidth="300.0">
         <children>
            <Label text="Correo Electrónico:" textFill="#374151">
               <font>
                  <Font name="System Bold" size="13.0" />
               </font>
            </Label>
            <TextField fx:id="txtCorreo" promptText="ejemplo@condo.com" prefHeight="35.0" />
         </children>
      </VBox>
      <Button fx:id="btnGenerar" mnemonicParsing="false" onAction="#accionGenerarClave" prefHeight="38.0" prefWidth="200.0" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-cursor: hand;" text="Generar Clave Temporal">
         <font>
            <Font name="System Bold" size="14.0" />
         </font>
         <VBox.margin>
            <Insets top="10.0" />
         </VBox.margin>
      </Button>
      <Button fx:id="btnRegresar" mnemonicParsing="false" onAction="#accionRegresarLogin" prefHeight="30.0" prefWidth="120.0" style="-fx-background-color: #6b7280; -fx-text-fill: white; -fx-cursor: hand;" text="Regresar al Login">
         <font>
            <Font size="12.0" />
         </font>
      </Button>
      <Label fx:id="lblMensaje" alignment="CENTER" textAlignment="CENTER" wrapText="true" maxWidth="350.0">
         <font>
            <Font size="13.0" />
         </font>
         <VBox.margin>
            <Insets top="10.0" />
         </VBox.margin>
      </Label>
   </children>
</VBox>