<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="450.0" prefWidth="650.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="proyecto_condominio.src.RegistroPagoViewController">

    <children>

        <!-- SCROLL GENERAL -->
        <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" pannable="true" style="-fx-background-color: transparent;" vbarPolicy="AS_NEEDED" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

            <content>

                <!-- CONTENEDOR CENTRAL -->
                <StackPane alignment="CENTER" prefHeight="448.0" prefWidth="689.0">

                    <children>

                        <VBox alignment="CENTER" fillWidth="false" maxWidth="820.0" prefHeight="498.0" prefWidth="820.0" spacing="18.0">

                            <padding>
                                <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
                            </padding>

                            <children>
                        <HBox alignment="TOP_RIGHT" prefWidth="850.0">
                           <children>
      
                                        <!-- BOTON -->
                                        <Button fx:id="btnRegresar" mnemonicParsing="false" onAction="#cerrarVentana" prefWidth="110.0" text="Regresar" />
                           </children>
                        </HBox>

                                <!-- ENCABEZADO -->
                                <HBox alignment="CENTER" prefWidth="550.0">

                                    <children>

                                        <!-- TITULO -->
                                        <Label alignment="CENTER" style="-fx-font-size: 22px; -fx-font-weight: bold;" text="Registro de Pago de Cuota" />

                                    </children>

                                </HBox>

                                <!-- CASA -->
                                <HBox alignment="CENTER" spacing="15.0">

                                    <children>

                                        <Label alignment="CENTER_RIGHT" prefWidth="180.0" text="Número de Casa:" />

                                        <ComboBox fx:id="cbCasa" onAction="#seleccionarCasa" prefWidth="170.0" />

                                    </children>

                                </HBox>

                                <!-- NOMBRE -->
                                <HBox alignment="CENTER" spacing="15.0">

                                    <children>

                                        <Label alignment="CENTER_RIGHT" prefWidth="180.0" text="Nombre completo:" />

                                        <TextField fx:id="txtNombre" editable="false" prefWidth="220.0" />

                                    </children>

                                </HBox>

                                <!-- APELLIDOS -->
                                <HBox alignment="CENTER" spacing="15.0">

                                    <children>

                                        <Label alignment="CENTER_RIGHT" prefWidth="180.0" text="Apellidos completos:" />

                                        <TextField fx:id="txtApellido" editable="false" prefWidth="220.0" />

                                    </children>

                                </HBox>

                                <!-- TELEFONO -->
                                <HBox alignment="CENTER" spacing="15.0">

                                    <children>

                                        <Label alignment="CENTER_RIGHT" prefWidth="180.0" text="Número de teléfono:" />

                                        <TextField fx:id="txtTelefono" editable="false" prefWidth="220.0" />

                                    </children>

                                </HBox>

                                <!-- CUOTA -->
                                <HBox alignment="CENTER" spacing="15.0">

                                    <children>

                                        <Label alignment="CENTER_RIGHT" prefWidth="180.0" text="Cuota mensual:" />

                                        <TextField fx:id="txtCuota" editable="false" prefWidth="220.0" />

                                    </children>

                                </HBox>
                        <HBox alignment="CENTER">
                           <children>
      
                                      <!-- AÑO -->
                                      <HBox alignment="CENTER" spacing="5.0">
      
                                          <children>
      
                                              <Label alignment="CENTER_RIGHT" prefWidth="50.0" text="Año:" />
      
                                              <ComboBox fx:id="cbAnio" prefWidth="100.0" />
      
                                          </children>
      
                                      </HBox>
      
                                      <!-- MES -->
                                      <HBox alignment="CENTER" spacing="5.0">
      
                                          <children>
      
                                              <Label alignment="CENTER_RIGHT" prefWidth="50.0" text="Mes:" />
      
                                              <ComboBox fx:id="cbMes" prefWidth="100.0" />
      
                                          </children>
      
                                      </HBox>
                           </children>
                        </HBox>

                                <!-- BOTON REGISTRAR -->
                                <HBox alignment="CENTER">

                                    <children>

                                        <Button fx:id="btnRegistrar" mnemonicParsing="false" onAction="#registrarPago" prefWidth="100.0" text="Registrar Pago" />

                                    </children>

                                </HBox>

                            </children>

                        </VBox>

                    </children>

                </StackPane>

            </content>

        </ScrollPane>

    </children>

</AnchorPane>
