<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane id="AnchorPane" prefHeight="290.0" prefWidth="586.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="proyecto_condominio.ui.ConfiguracionCuotaViewController">
   <children>
      <Label layoutX="237.0" layoutY="14.0" text="Configuración de Cuota" />
      <Label layoutX="101.0" layoutY="48.0" text="Cuota mensual de mantenimiento:" />
      <TextField fx:id="txtCuotaMensual" editable="false" layoutX="312.0" layoutY="44.0" text="Q1,500.00" />
      <Label layoutX="101.0" layoutY="79.0" text="Nueva cuota:" />
      <TextField fx:id="txtNuevaCuota" layoutX="313.0" layoutY="75.0" />
      <Label layoutX="101.0" layoutY="113.0" text="Recaudación mensual esperada:" />
      <TextField fx:id="txtRecaudacionMensual" layoutX="314.0" layoutY="109.0" text="Q45,000.00" />
      <TextField fx:id="lblHora" layoutX="217.0" layoutY="200.0" />
      <Label layoutX="154.0" layoutY="163.0" text="Fecha:" />
      <Label layoutX="156.0" layoutY="204.0" text="Hora (24h):" />
      <DatePicker fx:id="dpFechaModificacion" layoutX="217.0" layoutY="159.0" prefHeight="26.0" prefWidth="150.0" />
      <Button fx:id="btnGuardar" layoutX="217.0" layoutY="235.0" mnemonicParsing="false" onAction="#guardarConfiguracion" text="Guardar" />
      <Button fx:id="btnCancelar" layoutX="312.0" layoutY="235.0" mnemonicParsing="false" onAction="#regresarMenu" text="Cancelar" />
      <Button fx:id="btnRegresar" layoutX="512.0" layoutY="10.0" mnemonicParsing="false" onAction="#regresarMenu" text="Regresar" />
   </children>
</AnchorPane>
