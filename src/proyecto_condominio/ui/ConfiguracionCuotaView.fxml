<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="450.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="proyecto_condominio.src.ConfiguracionCuotaViewController">

    <children>

        <!-- SCROLL GENERAL -->
        <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" pannable="true" style="-fx-background-color: transparent;" vbarPolicy="AS_NEEDED" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

            <content>

                <!-- CONTENEDOR CENTRAL -->
                <StackPane alignment="CENTER" prefWidth="800.0">

                    <children>

                        <VBox alignment="CENTER" fillWidth="false" maxWidth="750.0" prefWidth="614.0" spacing="25.0">

                            <padding>
                                <Insets bottom="20.0" left="20.0" right="30.0" top="20.0" />
                            </padding>

                            <children>

                                <!-- BOTON REGRESAR -->
                                <HBox alignment="CENTER_RIGHT" prefWidth="700.0" spacing="15.0">

                                    <children>

                                        <Button fx:id="btnRegresar" mnemonicParsing="false" onAction="#regresarMenu" prefWidth="100.0" text="Regresar" />

                                    </children>

                                </HBox>

                                <!-- TITULO -->
                                <HBox alignment="CENTER" prefWidth="700.0" spacing="15.0">

                                    <children>

                                        <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Configuración de Cuota" />

                                    </children>

                                </HBox>

                                <!-- CUOTA MENSUAL -->
                                <HBox alignment="CENTER" spacing="15.0">

                                    <children>

                                        <Label alignment="CENTER_RIGHT" prefWidth="240.0" text="Cuota mensual de mantenimiento:" />

                                        <TextField fx:id="txtCuotaMensual" editable="false" maxWidth="350.0" prefWidth="230.0" text="Q1,500.00" />

                                    </children>

                                </HBox>

                                <!-- NUEVA CUOTA -->
                                <HBox alignment="CENTER" spacing="15.0">

                                    <children>

                                        <Label alignment="CENTER_RIGHT" prefWidth="240.0" text="Nueva cuota:" />

                                        <TextField fx:id="txtNuevaCuota" maxWidth="350.0" prefWidth="230.0" />

                                    </children>

                                </HBox>

                                <!-- RECAUDACION -->
                                <HBox alignment="CENTER" spacing="15.0">

                                    <children>

                                        <Label alignment="CENTER_RIGHT" prefWidth="240.0" text="Recaudación mensual esperada:" />

                                        <TextField fx:id="txtRecaudacionMensual" editable="false" maxWidth="350.0" prefWidth="230.0" text="Q45,000.00" />

                                    </children>

                                </HBox>

                                <!-- FECHA -->
                                <HBox alignment="CENTER" spacing="15.0">

                                    <children>

                                        <Label alignment="CENTER_RIGHT" prefWidth="240.0" text="Fecha:" />

                                        <DatePicker fx:id="dpFechaModificacion" maxWidth="350.0" prefWidth="230.0" />

                                    </children>

                                </HBox>

                                <!-- HORA -->
                                <HBox alignment="CENTER" spacing="15.0">

                                    <children>

                                        <Label alignment="CENTER_RIGHT" prefWidth="240.0" text="Hora (24h):" />

                                        <TextField fx:id="lblHora" editable="false" maxWidth="350.0" prefWidth="230.0" />

                                    </children>

                                </HBox>

                                <!-- BOTONES -->
                                <HBox alignment="CENTER" spacing="20.0">

                                    <children>

                                        <Button fx:id="btnGuardar" alignment="CENTER" mnemonicParsing="false" onAction="#guardarConfiguracion" prefWidth="100.0" text="Guardar" />

                                        <Button fx:id="btnCancelar" alignment="CENTER" mnemonicParsing="false" onAction="#regresarMenu" prefWidth="100.0" text="Cancelar" />

                                    </children>

                                </HBox>

                            </children>

                        </VBox>

                    </children>

                </StackPane>

            </content>

        </ScrollPane>

    </children>

</AnchorPane>
