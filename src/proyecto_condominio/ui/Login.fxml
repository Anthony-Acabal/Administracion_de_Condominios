<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="519.0" prefWidth="615.0" styleClass="fondo-pane" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="proyecto_condominio.ui.LoginController">
   <children>
      <AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="456.0" prefWidth="444.0" styleClass="card-central" stylesheets="@../css/styles.css" StackPane.alignment="CENTER">
         <children>
            <VBox alignment="CENTER" focusTraversable="true" layoutY="1.0" prefHeight="567.0" prefWidth="766.0" spacing="30.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
               <children>
                  <Label alignment="CENTER" prefHeight="39.0" prefWidth="112.0" styleClass="titulo" text="Login">
                     <font>
                        <Font size="31.0" />
                     </font>
                  </Label>
                  <TextField fx:id="txtCorreo" focusTraversable="false" prefHeight="27.0" prefWidth="649.0" promptText="Correo electrónico" styleClass="campo-texto">
                     <cursor>
                        <Cursor fx:constant="DEFAULT" />
                     </cursor>
                  </TextField>
                  <PasswordField fx:id="txtContrasena" prefHeight="27.0" prefWidth="240.0" promptText="Contraseña" styleClass="campo-texto" />
                  <Label fx:id="lblMensajeError" alignment="CENTER" prefHeight="17.0" prefWidth="382.0" styleClass="label-error" />
                  <Hyperlink onAction="#accionOlvidoContrasena" styleClass="label-form" text="¿Olvidó su contraseña?" textFill="#0f4c4a" />
                  <Button fx:id="btnIngresar" mnemonicParsing="false" onAction="#accionIngresar" prefHeight="27.0" prefWidth="100.0" styleClass="boton-primario" text="Ingresar" />
               </children>
               <padding>
                  <Insets bottom="50.0" left="50.0" right="50.0" top="50.0" />
               </padding>
            </VBox>
         </children>
      </AnchorPane>
   </children>
</StackPane>
