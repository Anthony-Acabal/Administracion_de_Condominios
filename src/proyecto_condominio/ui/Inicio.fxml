<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Accordion?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane id="AnchorPane" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="proyecto_condominio.controller.InicioController">
   <children>
      <Pane prefHeight="154.0" prefWidth="600.0" />
      <BorderPane fx:id="vistasContenedor" layoutX="-2.0" layoutY="-1.0" prefHeight="400.0" prefWidth="600.0">
         <top>
            <HBox prefHeight="100.0" prefWidth="200.0" spacing="30.0" BorderPane.alignment="CENTER">
               <children>
                  <Label fx:id="lblCondominio" text="Condominio Real" />
                  <Label fx:id="lblBienvenida" text="Bienvenido, Admin" />
                  <Label fx:id="lblFecha" text="Mayo, 2026" />
                  <VBox maxWidth="1.7976931348623157E308" prefHeight="200.0" prefWidth="180.0" spacing="15.0">
                     <children>
                        <Button fx:id="btnPropietarios" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#irPropietarios" text="Registro Propietario" />
                        <Button fx:id="btnPagos" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#irPagos" text="Registro de Pago" />
                        <Button fx:id="btnCuota" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#irCuota" text="Configuración Cuota" />
                        <Button fx:id="btnEstadosCuenta" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#irEstadosCuenta" text="Estados de Cuenta" />
                     </children>
                     <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                     </padding>
                  </VBox>
               </children>
            </HBox>
         </top>
         <bottom>
            <Button fx:id="btnCasasMorosas" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#irCasasMorosas" text="Casas Morosas" BorderPane.alignment="CENTER" />
         </bottom>
         <center>
            <Button fx:id="btnReporteGeneral" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#irReporteGeneral" text="Reporte General" BorderPane.alignment="CENTER" />
         </center>
      </BorderPane>
      <Accordion />
   </children>
</AnchorPane>
